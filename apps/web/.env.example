# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gateway provider (required for inference)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Optional — admin metrics API
# GATEWAY_ADMIN_SECRET=your-admin-secret

# Optional — local dev only, never set in production
# GATEWAY_DEV_BYPASS_KEY=dev-test-key

# Solana / wallet (optional until $GERCEP launch)
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# GERCEP_TOKEN_MINT=
# GERCEP_TOKEN_DECIMALS=9
